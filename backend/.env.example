# ── OBRIGATÓRIO ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── FONTE 1: JSearch via RapidAPI (200 req/mês free) ────────
# Agrega LinkedIn, Indeed, Glassdoor e mais numa só chamada
# Crie conta em: https://rapidapi.com → busque "JSearch" → subscribe Free
JSEARCH_API_KEY=your_rapidapi_key_here

# ── FONTE 2: SerpAPI (100 req/mês free) — backup do JSearch ─
# Quando JSearch estiver próximo do limite mensal
SERP_API_KEY=your_serpapi_key_here

# ── FONTE 3: Google Custom Search (100 req/dia free) ────────
# Fallback para Wellfound, WeWorkRemotely, EURemoteJobs
# API Key: https://console.cloud.google.com → Custom Search API
# CX ID:   https://programmablesearchengine.google.com
GOOGLE_API_KEY=
GOOGLE_CX=

# ── LinkedIn Direct: sem key necessária ─────────────────────
# Usa o pacote linkedin-jobs-api (npm) — scraping público
# Funciona automaticamente, sem configuração

PORT=3001
