# ── OBRIGATÓRIO ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── LINKEDIN via Apify (RECOMENDADO — substitui linkedin-jobs-api) ──
# Free tier: $5 crédito/mês recorrente (~12.500 vagas/mês)
# 1. Crie conta em: https://apify.com (sem cartão)
# 2. Vá em Settings → Integrations → API tokens → Create token
APIFY_TOKEN=your_apify_token_here

# ── JSearch via RapidAPI (200 req/mês free) ──────────────────
# Agrega Indeed, Glassdoor e mais — bom complemento ao Apify
# Crie conta em: https://rapidapi.com → busque "JSearch" → subscribe Free
JSEARCH_API_KEY=your_rapidapi_key_here

# ── SerpAPI (100 req/mês free) — backup do JSearch ───────────
SERP_API_KEY=your_serpapi_key_here

# ── Google Custom Search (100 req/dia free) ───────────────────
# Fallback para Wellfound, WeWorkRemotely, EURemoteJobs
# API Key: https://console.cloud.google.com → Custom Search API
# CX ID:   https://programmablesearchengine.google.com
GOOGLE_API_KEY=
GOOGLE_CX=

PORT=3001
